generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Ingredient {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  unit         String
  pricePerUnit Float
  tbspGrams    Float?
  tspGrams     Float?
  gramsPerUnit Float?   // 1個/1本あたりのg数（個・本・枚などの単位用）
  // 栄養素（100gあたり）
  kcal         Float?   // エネルギー (kcal)
  protein      Float?   // たんぱく質 (g)
  fat          Float?   // 脂質 (g)
  carbs        Float?   // 炭水化物 (g)
  fiber        Float?   // 食物繊維 (g)
  calcium      Float?   // カルシウム (mg)
  iron         Float?   // 鉄 (mg)
  vitA         Float?   // ビタミンA レチノール活性当量 (μg)
  vitB1        Float?   // ビタミンB1 (mg)
  vitB2        Float?   // ビタミンB2 (mg)
  vitC         Float?   // ビタミンC (mg)
  vitD         Float?   // ビタミンD (μg)
  vitE         Float?   // ビタミンE αトコフェロール (mg)
  salt         Float?   // 食塩相当量 (g)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  recipeIngredients RecipeIngredient[]
}

model Recipe {
  id           Int      @id @default(autoincrement())
  name         String
  description  String?
  photoPath    String?
  referenceUrl String?
  category     String?  @default("通常料理")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  versions RecipeVersion[]
}

model RecipeVersion {
  id            Int      @id @default(autoincrement())
  recipeId      Int
  versionNumber Int
  notes         String?
  steps         String
  photoPath     String?
  createdAt     DateTime @default(now())

  recipe      Recipe             @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredients RecipeIngredient[]

  @@unique([recipeId, versionNumber])
}

model RecipeIngredient {
  id              Int     @id @default(autoincrement())
  recipeVersionId Int
  ingredientId    Int?
  customName      String?
  amount          Float
  unit            String
  manualCost      Float?
  sectionName     String?

  recipeVersion RecipeVersion @relation(fields: [recipeVersionId], references: [id], onDelete: Cascade)
  ingredient    Ingredient?   @relation(fields: [ingredientId], references: [id])
}
